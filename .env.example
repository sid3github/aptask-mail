# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Claude (Anthropic) ──────────────────────────────────────────────────────
# Powers AI summaries, drafts, prioritization, semantic search.
ANTHROPIC_API_KEY=

# ─── Gmail OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Office 365 / Microsoft Graph ───────────────────────────────────────────
# https://entra.microsoft.com/ → App registrations
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# ─── IMAP credential encryption ─────────────────────────────────────────────
# 32-byte hex string (64 chars). Generate: openssl rand -hex 32
IMAP_ENCRYPTION_KEY=
